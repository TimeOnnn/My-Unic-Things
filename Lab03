namespace Study.Labs.Lab03
{
    class Train
    {
        public string DestinationPoint { get; set; }
        public string DeparturePoint { get; set; }
        public int Number { get; set; }
        public int NumberOfSeats { get; set; }

        public void PrintTrainInfo()
        {
            Console.WriteLine($"Поезд №{Number}");
            Console.WriteLine($"Из: {DeparturePoint}");
            Console.WriteLine($"В: {DestinationPoint}");
            Console.WriteLine($"Количество мест: {NumberOfSeats}");
        }
    }

    class Program
    {
        static void Main()
        {



        }
        static void NumberInput()
        {
            Train[] trains = new Train[]
            {
                new Train { DeparturePoint = "Москва", DestinationPoint = "Санкт-Петербург", Number = 1, NumberOfSeats = 500 },
                new Train { DeparturePoint = "Калининград", DestinationPoint = "Владивосток", Number = 2, NumberOfSeats = 800 },
                new Train { DeparturePoint = "Сургут", DestinationPoint = "Омск", Number = 3, NumberOfSeats = 400 },
                new Train { DeparturePoint = "Сочи", DestinationPoint = "Севастополь", Number = 4, NumberOfSeats = 400 },
                new Train { DeparturePoint = "Москва", DestinationPoint = "Казань", Number = 5, NumberOfSeats = 500 }
            };


            Console.WriteLine("Введите номер поезда");
            int inputNumber = Console.Read();

            if (inputNumber > 5)
                Console.WriteLine("Поезда с таким номером нет");

            Train foundedTrain = null;
            foreach (Train x in trains)
            {
                if (x.Number == inputNumber)
                {
                    foundedTrain = x;
                    break;
                }
            }
        }
    }
