        static void NumberInput(Train[] trains)
        {
            Console.WriteLine("Введите номер поезда");
            int inputNumber = int.Parse(Console.ReadLine());

            if (inputNumber > 5)
                Console.WriteLine("Поезда с таким номером нет");

            Train foundedTrain = null;
            foreach (Train x in trains)
            {
                if (x.Number == inputNumber)
                {
                    foundedTrain = x;
                    break;
                }
            }
            if (foundedTrain != null)
                foundedTrain.PrintTrainInfo();

        }
        static void NumberOfBiggestTrain(Train[] trains)
        {
            int biggestTrain = -2000, biggestTrainNumber = 0;

            foreach (Train x in trains)
            {
                if (x.NumberOfSeats >= biggestTrain)
                {
                    biggestTrain = x.NumberOfSeats;
                    biggestTrainNumber = x.Number;
                }
            }

            Console.WriteLine($"Поезд с наибольшим количеством посадочных мест под номером {biggestTrainNumber}");
            Console.WriteLine("----------------------------------------------------------------------------");
        }

         public static List<Product> FindingProduct(Product[] products, string ingredient)
        {

            string lowerIngridient;
            var list = new List<Product>();
            foreach (Product x in products)
            {
                lowerIngridient = x.Ingredients.ToLower();
                if (lowerIngridient.Contains(ingredient) || x.Ingredients.Contains(ingredient))
                    list.Add(x);
            }
            return list;
        }

        static void PrintCategoryCount(Product[] products)
        {
            int milk = 0, bread = 0, spice = 0, kitchen = 0;

            foreach (Product x in products)
            {
                if (x.Category == "Молочка")
                    milk++;
                else if (x.Category == "Выпечка")
                    bread++;
                else if (x.Category == "Специи")
                    spice++;
                else if (x.Category == "Кухонная утварь")
                    kitchen++;
            }
            Console.Write($"Количество продукции:\nМолочка: {milk},\nВыпечка: {bread},\nСпеции: {spice},\nКухонная утварь: {kitchen}\n");
            Console.WriteLine("----------------------------------------------------------------------------");
        }

        static void HighestExperiance(Employee[] employees)
        {
            Employee employee = null;
            int max = 0;
            for (int i = 0; i < 10; i++)
            {
                if (2026 - employees[i].HireYear > max)
                {
                    max = 2026 - employees[i].HireYear;
                    employee = employees[i];
                }
            }
            Console.WriteLine("Наибольший стаж:\n");
            employee.PrintEmployeeInfo();
        }

        static void FindingEmployeePost(Employee[] employees)
        {
            Console.WriteLine("Введите должность");
            string inputPost = Console.ReadLine();

            string lowerPost;
            foreach (Employee x in employees)
            {
                lowerPost = x.Post.ToLower();
                if (lowerPost.Contains(inputPost) || x.Post.Contains(inputPost))
                    x.PrintEmployeeInfo();
            }
        }
